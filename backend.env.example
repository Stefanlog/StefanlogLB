# Copy this file to backend.env and paste your TF2Easy session cookie below.
# Use the full Cookie header value from the getReferredUsers request.

TF2EASY_COOKIE=
HOST=0.0.0.0
PORT=8000
TF2EASY_CACHE_SECONDS=90
TF2EASY_FETCH_MODE=playwright
PLAYWRIGHT_BROWSER=chromium
PLAYWRIGHT_CHANNEL=
PLAYWRIGHT_EXECUTABLE_PATH=
PLAYWRIGHT_HEADLESS=1
PLAYWRIGHT_SETTLE_MS=2500
